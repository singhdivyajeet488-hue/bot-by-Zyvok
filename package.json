{
  "name": "discord-bot",
  "version": "1.0.0",
  "type": "module",
  "description": "A production-ready Discord bot with comprehensive features",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "docker:build": "docker build -t discord-bot .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "discord.js": "14.15.3",
    "@discordjs/rest": "2.3.0",
    "@discordjs/voice": "0.17.0",
    "mongoose": "8.5.3",
    "kazagumo": "2.2.4",
    "shoukaku": "4.0.1",
    "axios": "1.7.3",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "winston": "3.13.1",
    "node-cron": "3.0.3",
    "ms": "2.1.3",
    "moment": "2.30.1",
    "canvas": "2.11.2",
    "pino": "9.3.1",
    "ioredis": "5.4.1",
    "zlib-sync": "0.1.9",
    "bufferutil": "4.0.8",
    "utf-8-validate": "6.0.4"
  },
  "devDependencies": {
    "eslint": "9.8.0",
    "prettier": "3.3.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
